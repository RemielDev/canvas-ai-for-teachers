    {"type":"text","id":"mf_5_t","x":875,"y":1598,"width":610,"height":44,"text":"⑤ BubbleTree re-renders with the next row of options.  Teacher taps again.\nAt terminal:  preview  →  [Push to Canvas]  writes via  POST /api/v1/courses/..","originalText":"⑤ BubbleTree re-renders with the next row of options.  Teacher taps again.\nAt terminal:  preview  →  [Push to Canvas]  writes via  POST /api/v1/courses/..","fontSize":13,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#064e3b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":675003,"version":1,"versionNonce":675004,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.4},

