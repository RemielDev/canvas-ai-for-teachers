    {"type":"text","id":"inj_5_t","x":1555,"y":1568,"width":690,"height":70,"text":"Module view          /courses/:id/modules\n   →  inject inline per-module: \"🔧 AI-organize\"\n   →  BubbleTree: reorder · align to standards · add quiz\n   target:  div.context_module_items  →  header action","originalText":"Module view          /courses/:id/modules\n   →  inject inline per-module: \"🔧 AI-organize\"\n   →  BubbleTree: reorder · align to standards · add quiz\n   target:  div.context_module_items  →  header action","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e40af","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":685003,"version":1,"versionNonce":685004,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.45},

