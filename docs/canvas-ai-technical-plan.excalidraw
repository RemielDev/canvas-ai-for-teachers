    {"type":"text","id":"inj_2_t","x":1555,"y":1238,"width":690,"height":74,"text":"SpeedGrader          /courses/:id/gradebook/speed_grader\n   →  inject panel: \"Rubric-locked bulk feedback\"\n   →  BubbleTree: pick rubric criterion · pick student subset\n   target:  div#rubric_holder  sibling  →  slide-out drawer","originalText":"SpeedGrader          /courses/:id/gradebook/speed_grader\n   →  inject panel: \"Rubric-locked bulk feedback\"\n   →  BubbleTree: pick rubric criterion · pick student subset\n   target:  div#rubric_holder  sibling  →  slide-out drawer","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#4c1d95","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":682003,"version":1,"versionNonce":682004,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.45},

