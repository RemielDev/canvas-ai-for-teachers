    {"type":"text","id":"inj_4_t","x":1555,"y":1458,"width":690,"height":74,"text":"Course home          /courses/:id\n   →  inject floating button (bottom-right): \"🛠 Rebuild unit\"\n   →  BubbleTree: pick unit · scope · standards\n   target:  body  →  fixed-position FAB","originalText":"Course home          /courses/:id\n   →  inject floating button (bottom-right): \"🛠 Rebuild unit\"\n   →  BubbleTree: pick unit · scope · standards\n   target:  body  →  fixed-position FAB","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#064e3b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":684003,"version":1,"versionNonce":684004,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.45},

