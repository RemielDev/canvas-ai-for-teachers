    {"type":"text","id":"mf_4_t","x":875,"y":1468,"width":610,"height":74,"text":"④ Backend returns the NEXT BubbleNode  (or final result for terminal steps).\n   Shape:  { label, options: BubblePill[], requiresContext: string[] }\n   Streams via Server-Sent Events; service_worker pipes through port.postMessage.","originalText":"④ Backend returns the NEXT BubbleNode  (or final result for terminal steps).\n   Shape:  { label, options: BubblePill[], requiresContext: string[] }\n   Streams via Server-Sent Events; service_worker pipes through port.postMessage.","fontSize":13,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#4c1d95","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":674003,"version":1,"versionNonce":674004,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.4},

