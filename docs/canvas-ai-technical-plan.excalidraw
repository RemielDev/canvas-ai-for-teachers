    {"type":"text","id":"mf_2_t","x":875,"y":1228,"width":610,"height":54,"text":"② chrome.runtime.sendMessage({ type: 'action.step', actionId, picks })\n   content script → service_worker\n   typed via shared/messages.ts","originalText":"② chrome.runtime.sendMessage({ type: 'action.step', actionId, picks })\n   content script → service_worker\n   typed via shared/messages.ts","fontSize":13,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e40af","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":672003,"version":1,"versionNonce":672004,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.4},

