# Copy to .env and fill in. Each workspace reads from its own .env file;
# the shared vars below are the ones used across backend + web.

# --- Supabase (used by backend and web) ---
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>  # backend only; never expose client-side
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# --- Anthropic (backend only) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- JWT (backend only) ---
JWT_SECRET=<32-char random>           # openssl rand -hex 32

# --- KMS (production; empty = local dev crypto) ---
KMS_KEY_ID=

# --- Backend port (default 8787) ---
PORT=8787

# --- Web → backend pointer ---
BACKEND_URL=http://localhost:8787

# --- Extension build-time ---
VITE_BACKEND_URL=http://localhost:8787
