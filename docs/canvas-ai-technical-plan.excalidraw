    {"type":"rectangle","id":"tree_bg","x":100,"y":1110,"width":720,"height":540,"strokeColor":"#334155","backgroundColor":"#1e293b","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":660003,"version":1,"versionNonce":660004,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"roundness":{"type":3}},
    {"type":"text","id":"tree_b","x":120,"y":1125,"width":680,"height":510,"text":"canvas-ai-extension/\n├─ manifest.json         v3  ·  permissions below\n├─ vite.config.ts        CRXJS plugin  ·  HMR  ·  TS strict\n├─ src/\n│   ├─ background/\n│   │   └─ service_worker.ts     long-lived broker\n│   │                            auth  ·  API calls  ·  SSE stream\n│   ├─ content/\n│   │   ├─ mount.ts              page-type detect  ·  React root\n│   │   ├─ bubbles/\n│   │   │   ├─ BubbleTree.tsx    the star component\n│   │   │   ├─ BubblePill.tsx    individual bubble\n│   │   │   └─ OtherInput.tsx    ✏ fallback  —  only typing path\n│   │   └─ targets/              per-page injectors\n│   │       ├─ assignment-editor.tsx\n│   │       ├─ speedgrader.tsx\n│   │       ├─ gradebook.tsx\n│   │       ├─ course-home.tsx\n│   │       └─ module-view.tsx\n│   ├─ popup/Popup.tsx           toolbar popup\n│   ├─ options/Options.tsx       settings, PAT mgmt\n│   └─ shared/\n│       ├─ canvas-client.ts      fetch  /api/v1/*  credentials:'include'\n│       ├─ backend-client.ts     fetch  api.canvasai.app  + JWT\n│       ├─ messages.ts           typed chrome.runtime contracts\n│       ├─ storage.ts            chrome.storage  +  IndexedDB wrapper\n│       └─ bubble-spec.ts        shared schema w/ backend\n└─ tests/                        Playwright  ·  FFT sandbox","originalText":"canvas-ai-extension/\n├─ manifest.json         v3  ·  permissions below\n├─ vite.config.ts        CRXJS plugin  ·  HMR  ·  TS strict\n├─ src/\n│   ├─ background/\n│   │   └─ service_worker.ts     long-lived broker\n│   │                            auth  ·  API calls  ·  SSE stream\n│   ├─ content/\n│   │   ├─ mount.ts              page-type detect  ·  React root\n│   │   ├─ bubbles/\n│   │   │   ├─ BubbleTree.tsx    the star component\n│   │   │   ├─ BubblePill.tsx    individual bubble\n│   │   │   └─ OtherInput.tsx    ✏ fallback  —  only typing path\n│   │   └─ targets/              per-page injectors\n│   │       ├─ assignment-editor.tsx\n│   │       ├─ speedgrader.tsx\n│   │       ├─ gradebook.tsx\n│   │       ├─ course-home.tsx\n│   │       └─ module-view.tsx\n│   ├─ popup/Popup.tsx           toolbar popup\n│   ├─ options/Options.tsx       settings, PAT mgmt\n│   └─ shared/\n│       ├─ canvas-client.ts      fetch  /api/v1/*  credentials:'include'\n│       ├─ backend-client.ts     fetch  api.canvasai.app  + JWT\n│       ├─ messages.ts           typed chrome.runtime contracts\n│       ├─ storage.ts            chrome.storage  +  IndexedDB wrapper\n│       └─ bubble-spec.ts        shared schema w/ backend\n└─ tests/                        Playwright  ·  FFT sandbox","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#22c55e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":660005,"version":1,"versionNonce":660006,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.55},

