    {"type":"text","id":"inj_3_t","x":1555,"y":1348,"width":690,"height":74,"text":"Gradebook            /courses/:id/gradebook\n   →  inject overlay badge: \"⚠ 3 at-risk students — tap to open radar\"\n   →  BubbleTree: pick student · pick intervention\n   target:  top of  div.gradebook  →  floating badge","originalText":"Gradebook            /courses/:id/gradebook\n   →  inject overlay badge: \"⚠ 3 at-risk students — tap to open radar\"\n   →  BubbleTree: pick student · pick intervention\n   target:  top of  div.gradebook  →  floating badge","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#7f1d1d","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":683003,"version":1,"versionNonce":683004,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.45},

