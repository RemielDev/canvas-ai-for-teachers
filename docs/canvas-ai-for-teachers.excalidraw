		{
			"type": "text",
			"id": "iAEab2Di",
			"x": 860,
			"y": 990,
			"width": 624.1015625,
			"height": 131.95,
			"text": "Haiku reads /analytics + /submissions and surfaces at-risk students:\n\n   ●  3 missed assignments, trending down in Unit 3  →  draft outreach email\n   ●  Strong on quizzes, weak on writing   →  differentiated worksheet\n   ●  First drop after Spring Break   →  parent message, 2 languages\n\nTime-back feature. Teacher clicks \"send\" — not \"write this for me from scratch\".",
			"originalText": "Haiku reads /analytics + /submissions and surfaces at-risk students:\n\n   ●  3 missed assignments, trending down in Unit 3  →  draft outreach email\n   ●  Strong on quizzes, weak on writing   →  differentiated worksheet\n   ●  First drop after Spring Break   →  parent message, 2 languages\n\nTime-back feature. Teacher clicks \"send\" — not \"write this for me from scratch\".",
			"fontSize": 13,
			"fontFamily": 3,
			"textAlign": "left",
			"verticalAlign": "top",
			"strokeColor": "#7f1d1d",
			"backgroundColor": "transparent",
