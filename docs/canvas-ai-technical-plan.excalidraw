    {"type":"text","id":"mf_3_t","x":875,"y":1338,"width":610,"height":74,"text":"③ service_worker:\n   •  reads/writes chrome.storage (cache, JWT)\n   •  fetches Canvas /api/v1/* with credentials:'include'  (no token needed on page)\n   •  POSTs to backend/action/step with JWT  →  LLM + pgvector retrieval","originalText":"③ service_worker:\n   •  reads/writes chrome.storage (cache, JWT)\n   •  fetches Canvas /api/v1/* with credentials:'include'  (no token needed on page)\n   •  POSTs to backend/action/step with JWT  →  LLM + pgvector retrieval","fontSize":13,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#7c2d12","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":673003,"version":1,"versionNonce":673004,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.4},

