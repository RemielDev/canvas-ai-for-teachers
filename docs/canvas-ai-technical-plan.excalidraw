    {"type":"rectangle","id":"locality","x":100,"y":690,"width":560,"height":260,"strokeColor":"#334155","backgroundColor":"#1e293b","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":640001,"version":1,"versionNonce":640002,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"roundness":{"type":3}},
    {"type":"text","id":"locality_h","x":120,"y":705,"width":520,"height":24,"text":"Data locality  —  what lives where","originalText":"Data locality  —  what lives where","fontSize":16,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#fbbf24","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":640003,"version":1,"versionNonce":640004,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
    {"type":"text","id":"locality_b","x":120,"y":740,"width":520,"height":200,"text":"SERVER  (Supabase Postgres + pgvector)\n   all tables above.  RLS per teacher_id / org_id.\n   embeddings, raw_text, credentials — authoritative.\n\nCHROME EXTENSION  (chrome.storage.local + IndexedDB)\n   cached course list, last-scan timestamp, recent bubble trees.\n   session JWT only.  NO student PII, NO embeddings, NO PAT plaintext.\n   everything clears on sign-out or 7-day TTL.\n\nWEB APP  (Next.js)\n   SWR cache only, server-side sessions (http-only cookie).\n   no persistent client store.","originalText":"SERVER  (Supabase Postgres + pgvector)\n   all tables above.  RLS per teacher_id / org_id.\n   embeddings, raw_text, credentials — authoritative.\n\nCHROME EXTENSION  (chrome.storage.local + IndexedDB)\n   cached course list, last-scan timestamp, recent bubble trees.\n   session JWT only.  NO student PII, NO embeddings, NO PAT plaintext.\n   everything clears on sign-out or 7-day TTL.\n\nWEB APP  (Next.js)\n   SWR cache only, server-side sessions (http-only cookie).\n   no persistent client store.","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#22c55e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":640005,"version":1,"versionNonce":640006,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.5},

    {"type":"rectangle","id":"safety","x":700,"y":690,"width":620,"height":260,"strokeColor":"#334155","backgroundColor":"#1e293b","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":641001,"version":1,"versionNonce":641002,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"roundness":{"type":3}},
    {"type":"text","id":"safety_h","x":720,"y":705,"width":580,"height":24,"text":"Safety & compliance controls","originalText":"Safety & compliance controls","fontSize":16,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#fbbf24","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":641003,"version":1,"versionNonce":641004,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
    {"type":"text","id":"safety_b","x":720,"y":740,"width":580,"height":200,"text":"•  canvas_credentials.token_enc  →  KMS envelope encryption (AWS KMS / GCP KMS)\n•  Row-Level Security on every table, scoped by teacher_id or org_id\n•  course_contexts.raw_text  →  excluded from LLM training, retention 30d by default,\n    configurable per org.  Student-authored text  →  zero-retention mode always.\n•  usage_events is the only FERPA-adjacent audit log; immutable, 7-year retention\n•  Soft-delete cascade from teacher → courses → contexts → embeddings (30d purge)\n•  Every LLM call stamps audit_id, model, input_hash, output_hash","originalText":"•  canvas_credentials.token_enc  →  KMS envelope encryption (AWS KMS / GCP KMS)\n•  Row-Level Security on every table, scoped by teacher_id or org_id\n•  course_contexts.raw_text  →  excluded from LLM training, retention 30d by default,\n    configurable per org.  Student-authored text  →  zero-retention mode always.\n•  usage_events is the only FERPA-adjacent audit log; immutable, 7-year retention\n•  Soft-delete cascade from teacher → courses → contexts → embeddings (30d purge)\n•  Every LLM call stamps audit_id, model, input_hash, output_hash","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#ffffff","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":641005,"version":1,"versionNonce":641006,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.5},

    {"type":"text","id":"s2_label","x":80,"y":1000,"width":1400,"height":30,"text":"02  —  Chrome Extension framework  (Manifest V3  +  Vite/CRXJS  +  React 18 + TypeScript)","originalText":"02  —  Chrome Extension framework  (Manifest V3  +  Vite/CRXJS  +  React 18 + TypeScript)","fontSize":22,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#3b82f6","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":650001,"version":1,"versionNonce":650002,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
