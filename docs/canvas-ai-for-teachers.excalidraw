		{
			"type": "text",
			"id": "OgkR7Vcy",
			"x": 1220,
			"y": 282,
			"width": 382.26220703125,
			"height": 218.39999999999998,
			"text": "POST  /api/v1/accounts/:id/courses\nPOST  /api/v1/courses/:id/assignments\nPOST  /api/v1/courses/:id/modules\nPOST  /api/v1/courses/:id/quizzes\nPOST  /api/v1/courses/:id/pages\nGET    /api/v1/courses/:id/students/submissions\nGET    /api/v1/courses/:id/analytics/assignments\nPOST  /api/v1/courses/:id/rubrics\n\n— auth: PAT (free tier, self-serve)\n— auth: OAuth2 dev key (district, admin-approved)\n— throttle: ~700 cost units, ~10 req/s sustained",
			"originalText": "POST  /api/v1/accounts/:id/courses\nPOST  /api/v1/courses/:id/assignments\nPOST  /api/v1/courses/:id/modules\nPOST  /api/v1/courses/:id/quizzes\nPOST  /api/v1/courses/:id/pages\nGET    /api/v1/courses/:id/students/submissions\nGET    /api/v1/courses/:id/analytics/assignments\nPOST  /api/v1/courses/:id/rubrics\n\n— auth: PAT (free tier, self-serve)\n— auth: OAuth2 dev key (district, admin-approved)\n— throttle: ~700 cost units, ~10 req/s sustained",
			"fontSize": 13,
